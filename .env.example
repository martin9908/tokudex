# TokuDex environment variables — copy to .env.local and fill in.
# Get values from Supabase → Settings → API.

# Public (safe to expose to the browser; per-user safety relies on RLS being ON):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — used for account deletion (auth.admin.deleteUser).
# NEVER prefix with NEXT_PUBLIC_ and never expose to the client.
# Also add this to the Vercel project's Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=
